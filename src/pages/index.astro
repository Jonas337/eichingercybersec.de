---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactSection from '../components/ContactSection.astro';
import { organizationSchema, webSiteSchema } from '../utils/jsonld';

const services = [
  {
    title: 'E-Mail-Sicherheit',
    description: 'Schutz vor Phishing, Spam und Business Email Compromise durch fortschrittliche E-Mail-Sicherheitslösungen.',
  },
  {
    title: 'Penetrations Tests',
    description: 'Identifikation von Schwachstellen in Ihrer IT-Infrastruktur durch simulierte Angriffe – bevor echte Angreifer sie finden.',
  },
  {
    title: 'Vulnerability Management',
    description: 'Kontinuierliche Überwachung Ihrer Systeme auf bekannte Sicherheitslücken mit automatisierten Scanning-Tools.',
  },
  {
    title: 'IT-Risikoanalyse & Strategie',
    description: 'Systematische Bewertung Ihrer IT-Risiken und Entwicklung einer maßgeschneiderten Sicherheitsstrategie.',
  },
  {
    title: 'Zertifizierung (TISAX, ISO 27001 & NIS2)',
    description: 'Begleitung auf dem Weg zur Sicherheitszertifizierung und NIS2-Compliance – von der Gap-Analyse bis zum erfolgreichen Audit.',
  },
  {
    title: 'Endpoint & Server Sicherheit',
    description: 'Umfassender Schutz für Arbeitsplatzrechner und Server durch moderne Endpoint-Protection-Lösungen.',
  },
  {
    title: 'Incident Response',
    description: 'Schnelle und professionelle Reaktion auf Cybersecurity-Vorfälle – Schadensbegrenzung und Wiederherstellung.',
  },
];

const jsonLd = [organizationSchema(), webSiteSchema()];
---

<BaseLayout
  title="Eichinger Cybersec – Cybersicherheit für KMU"
  description="Individuelle Sicherheitslösungen für KMU. E-Mail-Schutz, Penetrationstests, Schwachstellenscanning, IT-Risikoanalysen und Zertifizierungen."
  keywords="Cybersicherheit, KMU, IT-Sicherheit, Penetrationstests, E-Mail-Sicherheit, Schwachstellenscanning, NIS2, TISAX, ISO 27001"
  jsonLd={jsonLd}
>
  <Hero />

  <section class="section intro-section">
    <div class="container">
      <p class="intro-text reveal">
        Cybersicherheit ist für jedes Unternehmen unverzichtbar – besonders für den Mittelstand.
        Eichinger Cybersec bietet Ihnen individuelle Sicherheitslösungen,
        die Ihr Unternehmen zuverlässig vor Cyberbedrohungen schützen.
        Von Penetrationstests über E-Mail-Sicherheit bis hin zu Zertifizierungen –
        wir sorgen dafür, dass Ihre IT-Infrastruktur gegen aktuelle Bedrohungen gewappnet ist.
      </p>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="section-header reveal">
        <h2>Unsere Dienstleistungen</h2>
        <p>Umfassende Cybersicherheit, speziell für kleine und mittelständische Unternehmen.</p>
      </div>
      <div class="services-grid stagger-children">
        {services.map((service) => (
          <div class="reveal">
            <ServiceCard {...service} />
          </div>
        ))}
      </div>
      <div class="services-cta reveal">
        <a href="/dienstleistungen" class="btn btn-outline">Alle Leistungen im Detail &rarr;</a>
      </div>
    </div>
  </section>

  <section class="section values-section">
    <div class="container">
      <div class="section-header reveal">
        <h2>Warum Eichinger Cybersec?</h2>
      </div>
      <div class="values-grid stagger-children">
        <div class="value-item reveal">
          <h3>KMU-fokussiert</h3>
          <p>Wir verstehen die Herausforderungen und Budgets kleiner und mittelständischer Unternehmen – und passen unsere Lösungen entsprechend an.</p>
        </div>
        <div class="value-item reveal">
          <h3>Individuelle Beratung</h3>
          <p>Keine Standardlösungen. Wir analysieren Ihre spezifische Situation und entwickeln eine Sicherheitsstrategie, die zu Ihnen passt.</p>
        </div>
        <div class="value-item reveal">
          <h3>Zertifizierte Expertise</h3>
          <p>Fundiertes Fachwissen in aktuellen Bedrohungsszenarien, Sicherheitsstandards und Zertifizierungsanforderungen.</p>
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>

<style>
  .intro-section {
    text-align: center;
  }

  .intro-text {
    max-width: 800px;
    margin-inline: auto;
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
  }

  .services-cta {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  .values-section {
    background: var(--color-surface);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .value-item {
    text-align: center;
    padding: var(--space-xl);
  }

  .value-item h3 {
    margin-bottom: var(--space-sm);
  }

  .value-item p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
  }
</style>
