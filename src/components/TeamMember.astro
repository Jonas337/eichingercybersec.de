---
interface Props {
  name: string;
  role: string;
  bio: string;
  initials?: string;
  linkedin?: string;
  email?: string;
}

const { name, role, bio, initials, linkedin, email } = Astro.props;
const displayInitials = initials ?? name.split(' ').map(w => w[0]).join('');
---

<article class="member-card">
  <div class="avatar">
    <span>{displayInitials}</span>
  </div>
  <h3>{name}</h3>
  <p class="role">{role}</p>
  <p class="bio">{bio}</p>
  {(linkedin || email) && (
    <div class="social-links">
      {linkedin && (
        <a href={linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${name} auf LinkedIn`}>
          LinkedIn
        </a>
      )}
      {email && (
        <a href={`mailto:${email}`} aria-label={`E-Mail an ${name}`}>
          E-Mail
        </a>
      )}
    </div>
  )}
</article>

<style>
  .member-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-2xl);
    text-align: center;
    transition: all var(--transition-base);
  }

  .member-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
  }

  .avatar span {
    color: #fff;
    font-size: var(--text-2xl);
    font-weight: 600;
  }

  h3 {
    margin-bottom: var(--space-xs);
  }

  .role {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-md);
  }

  .bio {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
  }

  .social-links a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .social-links a:hover {
    color: var(--color-accent);
  }
</style>
